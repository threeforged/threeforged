{
  "name": "@threeforged/cli",
  "version": "0.1.6",
  "type": "module",
  "description": "Command-line interface for ThreeForged — optimize Three.js assets and scenes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/threeforged/threeforged.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/threeforged/threeforged/tree/main/packages/cli#readme",
  "bugs": "https://github.com/threeforged/threeforged/issues",
  "keywords": ["threejs", "three.js", "3d", "optimization", "cli", "gltf", "glb", "performance"],
  "bin": {
    "threeforged": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@threeforged/core": "^0.1.1",
    "cli-table3": "^0.6.0",
    "commander": "^12.0.0",
    "picocolors": "^1.0.0"
  },
  "optionalDependencies": {
    "@threeforged/asset-analyzer": "^0.1.2",
    "@threeforged/performance-auditor": "^0.1.2",
    "@threeforged/lod-generator": "^0.1.1",
    "@threeforged/instancing-optimizer": "^0.1.1",
    "@threeforged/static-optimizer": "^0.1.3"
  }
}
