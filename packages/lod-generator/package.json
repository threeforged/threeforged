{
  "name": "@threeforged/lod-generator",
  "version": "0.1.0",
  "type": "module",
  "description": "Generate levels of detail for Three.js meshes — automatic mesh simplification for distance-based rendering",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/threeforged/threeforged.git",
    "directory": "packages/lod-generator"
  },
  "homepage": "https://github.com/threeforged/threeforged/tree/main/packages/lod-generator#readme",
  "bugs": "https://github.com/threeforged/threeforged/issues",
  "keywords": ["threejs", "three.js", "3d", "lod", "level-of-detail", "mesh-simplification", "optimization"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@threeforged/core": "workspace:*",
    "@gltf-transform/core": "^4.0.0",
    "@gltf-transform/functions": "^4.0.0",
    "meshoptimizer": "^0.20.0"
  }
}
