{
  "name": "@threeforged/static-optimizer",
  "version": "0.1.2",
  "type": "module",
  "description": "Optimize static geometry in Three.js scenes — merge non-moving meshes to reduce draw calls",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/threeforged/threeforged.git",
    "directory": "packages/static-optimizer"
  },
  "homepage": "https://github.com/threeforged/threeforged/tree/main/packages/static-optimizer#readme",
  "bugs": "https://github.com/threeforged/threeforged/issues",
  "keywords": ["threejs", "three.js", "3d", "static-geometry", "mesh-merging", "batching", "optimization"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@threeforged/core": "workspace:*",
    "@gltf-transform/core": "^4.0.0",
    "@gltf-transform/functions": "^4.0.0"
  }
}
