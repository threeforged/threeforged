{
  "name": "@threeforged/asset-analyzer",
  "version": "0.1.0",
  "type": "module",
  "description": "Asset analysis plugin for ThreeForged",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@threeforged/core": "workspace:*",
    "commander": "^12.0.0"
  }
}
