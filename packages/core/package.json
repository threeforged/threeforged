{
  "name": "@threeforged/core",
  "version": "0.1.1",
  "type": "module",
  "description": "Shared foundation for ThreeForged tools — types, loaders, config, and utilities",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/threeforged/threeforged.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/threeforged/threeforged/tree/main/packages/core#readme",
  "bugs": "https://github.com/threeforged/threeforged/issues",
  "keywords": ["threejs", "three.js", "3d", "optimization", "gltf", "glb", "obj"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.0.0",
    "globby": "^14.0.0",
    "obj-file-parser": "^0.6.0",
    "picocolors": "^1.0.0"
  }
}
